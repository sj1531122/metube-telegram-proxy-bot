# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:replace-with-your-real-bot-token
TELEGRAM_ALLOWED_CHAT_ID=123456789

# Remote MeTube API
METUBE_BASE_URL=https://metube-api.example.com

# Optional MeTube API auth header pair.
# Leave both empty if your reverse proxy does not require API auth.
METUBE_AUTH_HEADER_NAME=Authorization
METUBE_AUTH_HEADER_VALUE=Bearer replace-with-your-api-token

# Public direct-download base URLs returned to Telegram after completion.
# These should be reachable by your phone/Telegram client.
PUBLIC_HOST_URL=https://downloads.example.com/download
PUBLIC_HOST_AUDIO_URL=https://downloads.example.com/audio_download

# Local bot persistence
BOT_SQLITE_PATH=bot/tasks.sqlite3

# HTTP and task behavior
BOT_HTTP_TIMEOUT_SECONDS=30
BOT_POLL_INTERVAL_SECONDS=15
BOT_TASK_TIMEOUT_SECONDS=21600
BOT_DEDUPE_WINDOW_SECONDS=300
