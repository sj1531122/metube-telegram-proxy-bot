# Telegram
TELEGRAM_BOT_TOKEN=1234567890:replace-with-your-real-bot-token
TELEGRAM_ALLOWED_CHAT_ID=123456789

# Public direct download base URL returned to Telegram.
# This must point to the public /download path exposed by your reverse proxy.
PUBLIC_DOWNLOAD_BASE_URL=https://downloads.example.com/download

# Optional proxy subscription.
VPN_SUBSCRIPTION_URL=https://example.com/subscription

# Local runtime paths inside the container.
DOWNLOAD_DIR=/downloads
STATE_DIR=/state

# Optional path to a mounted Netscape cookies.txt file inside the container.
# Leave blank to run without cookies support.
COOKIES_FILE=

# Optional extra yt-dlp flags, parsed with shell-style splitting.
YTDLP_EXTRA_ARGS=

# Embedded HTTP file server.
HTTP_BIND=0.0.0.0
HTTP_PORT=8081
HTTP_TIMEOUT_SECONDS=30

# Bot behavior.
POLL_INTERVAL_SECONDS=1
TASK_TIMEOUT_SECONDS=21600
BOT_DEDUPE_WINDOW_SECONDS=300
